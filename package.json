{
  "name": "relay",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:smoke:production": "playwright test --config playwright.production.config.ts",
    "bundle:check": "node scripts/check-bundle-size.mjs",
    "performance:check": "lhci autorun",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test",
    "release:check": "pnpm check && pnpm build && pnpm bundle:check && pnpm db:verify && pnpm test:e2e",
    "db:start": "supabase start -x edge-runtime",
    "db:start:ci": "supabase start -x edge-runtime,gotrue,imgproxy,kong,logflare,mailpit,postgres-meta,postgrest,realtime,storage-api,studio,supavisor,vector",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:lint": "supabase db lint --local --schema public --level warning --fail-on error",
    "db:test": "supabase test db --local",
    "db:types": "node scripts/database-types.mjs",
    "db:types:check": "node scripts/database-types.mjs --check",
    "db:verify": "pnpm db:reset && pnpm db:lint && pnpm db:test && pnpm db:types:check"
  },
  "dependencies": {
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@sentry/nextjs": "^10.59.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tanstack/react-query": "5.101.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "motion": "^12.40.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "nodemailer": "^9.0.1",
    "radix-ui": "^1.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.14.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tus-js-client": "4.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "supabase": "^2.107.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^6.4.3",
    "vitest": "^4.1.9"
  }
}
