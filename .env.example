# Public application and Supabase values. Local defaults are printed by `pnpm db:start`.
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional observability. The public DSN may be exposed to browsers; keep the
# auth token server-side and scope it to source-map uploads only.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Required in production for server-only account deletion. Local development
# reads the temporary secret from the running Supabase CLI when this is empty.
SUPABASE_SECRET_KEY=

# Replace these local-safe placeholders to use Google sign-in. Keep the real client
# secret in the ignored root `.env` file and never use a `NEXT_PUBLIC_` variable.
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=replace-with-google-client-id
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# Workspace invitations use local Mailpit by default. Set RESEND_API_KEY and a
# verified sender before production deployment.
MAILPIT_SMTP_URL=smtp://127.0.0.1:54325
RESEND_API_KEY=
INVITATION_FROM_EMAIL=Relay <onboarding@resend.dev>
