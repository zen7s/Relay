# Public application and Supabase values. Local defaults are printed by `pnpm db:start`.
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Replace these local-safe placeholders to use Google sign-in. Keep the real client
# secret in the ignored root `.env` file and never use a `NEXT_PUBLIC_` variable.
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=replace-with-google-client-id
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
